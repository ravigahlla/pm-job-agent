# Copy to `.env` and fill in locally. Never commit `.env`.
# CI: use GitHub Actions secrets or environment variables instead of files.

# Path to gitignored career context (default suits local dev.)
AGENT_CONTEXT_PATH=private/agent-context.md

# Job sources (names vary by product; set what your integration code expects.)
# GREENHOUSE_API_KEY=
# GREENHOUSE_BOARD_TOKEN=
# ADZUNA_APP_ID=
# ADZUNA_APP_KEY=

# Slack
# SLACK_BOT_TOKEN=
# SLACK_CHANNEL_ID=

# LLM providers (enable the one(s) your model wrapper uses.)
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# GOOGLE_API_KEY=
