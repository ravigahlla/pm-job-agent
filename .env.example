# Copy to `.env` and fill in locally. Never commit `.env`.
# CI: use GitHub Actions secrets or environment variables instead of files.

# Path to gitignored career context (default suits local dev.)
AGENT_CONTEXT_PATH=private/agent-context.md

# Path to gitignored search profile (titles, keywords, target company tokens).
SEARCH_PROFILE_PATH=private/search_profile.yaml

# Directory for timestamped CSV run outputs (gitignored).
# OUTPUT_DIR=outputs

# LLM provider to use: stub | anthropic | openai | gemini | ollama
DEFAULT_LLM_PROVIDER=stub

# Job sources (names vary by product; set what your integration code expects.)
# GREENHOUSE_API_KEY=
# GREENHOUSE_BOARD_TOKEN=
# ADZUNA_APP_ID=
# ADZUNA_APP_KEY=

# Slack (planned): ingest job posts from a channel — bot needs history/read scopes for that channel.
# Optional later: post notifications (may use same or different app config).
# SLACK_BOT_TOKEN=
# SLACK_JOBS_CHANNEL_ID=

# LLM providers (set the key for whichever provider you select above.)
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# GOOGLE_API_KEY=

# Model names — defaults shown; override to swap models without code changes.
# ANTHROPIC_MODEL=claude-3-5-haiku-20241022
# OPENAI_MODEL=gpt-4o-mini
# GEMINI_MODEL=gemini-1.5-flash
# OLLAMA_MODEL=llama3.2
# OLLAMA_BASE_URL=http://localhost:11434
