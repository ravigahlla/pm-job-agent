# Copy to `.env` and fill in locally. Never commit `.env`.
# CI: use GitHub Actions secrets or environment variables instead of files.

# Path to gitignored career context (default suits local dev.)
AGENT_CONTEXT_PATH=private/agent-context.md

# Path to gitignored search profile (titles, keywords, target company tokens).
SEARCH_PROFILE_PATH=private/search_profile.yaml

# Directory for timestamped CSV run outputs (gitignored).
# OUTPUT_DIR=outputs

# LLM provider to use: stub | anthropic | openai | gemini | ollama
DEFAULT_LLM_PROVIDER=stub

# Job sources
# Greenhouse: no key required — boards are public. Add board tokens to search_profile.yaml.
# LinkedIn via Apify: get your token at https://console.apify.com/account/integrations
# APIFY_API_TOKEN=

# Slack (planned): ingest job posts from a channel — bot needs history/read scopes for that channel.
# Optional later: post notifications (may use same or different app config).
# SLACK_BOT_TOKEN=
# SLACK_JOBS_CHANNEL_ID=

# Email digest via Gmail SMTP (optional — run still works without it, no email is sent).
# Setup: enable 2-Step Verification on your Google account, then generate an App Password at
#   https://myaccount.google.com/apppasswords  (select "Mail" → your device)
# GMAIL_SENDER=you@gmail.com
# GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx
# NOTIFY_EMAIL=you@gmail.com    # recipient; can be same as sender
# NOTIFY_TOP_N=20               # number of jobs to include in the email table

# LLM providers (set the key for whichever provider you select above.)
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# GOOGLE_API_KEY=

# Model names — defaults shown; override to swap models without code changes.
# ANTHROPIC_MODEL=claude-3-5-haiku-20241022
# OPENAI_MODEL=gpt-4o-mini
# GEMINI_MODEL=gemini-1.5-flash
# OLLAMA_MODEL=llama3.2
# OLLAMA_BASE_URL=http://localhost:11434
